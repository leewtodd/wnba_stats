<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  WNBA Stats Daily Pull LaunchAgent

  Install: cp scripts/com.wnba-stats.daily-pull.plist ~/Library/LaunchAgents/
  Load:    launchctl load ~/Library/LaunchAgents/com.wnba-stats.daily-pull.plist
  Unload:  launchctl unload ~/Library/LaunchAgents/com.wnba-stats.daily-pull.plist
  Test:    launchctl start com.wnba-stats.daily-pull
  Logs:    ~/Library/Logs/wnba-stats/daily-pull.log
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wnba-stats.daily-pull</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/leetodd/Desktop/Projects/wnba_stats/scripts/daily_pull.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/leetodd/Desktop/Projects/wnba_stats</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/leetodd/Library/Logs/wnba-stats/daily-pull-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/leetodd/Library/Logs/wnba-stats/daily-pull-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
